# copiar para .env e ajustar
PGHOST=localhost
PGPORT=5432
PGDATABASE=frota
PGUSER=frota
PGPASSWORD=frota

# mes de referencia do dump SENATRAN (formato: abril_2026)
SENATRAN_MES=abril_2026

# usar amostra versionada (data/samples) em vez do dump full
# em portfolio deixe SAMPLE=1 pra rodar sem baixar 1.2GB
USE_SAMPLE=1
